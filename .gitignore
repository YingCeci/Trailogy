# Superpowers docs — generated, not committed
docs/superpowers/

src/finetune/results/
src/finetune/logs/
src/quantization/results/
src/quantization/logs/

# Xcode
*.xcodeproj/
!project.yml
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
DerivedData/
build/
*.dSYM.zip
*.dSYM

# SwiftPM (anywhere in tree, including vendored packages under external/)
.swiftpm/
**/.build/
Package.resolved
external/**/Package.resolved

# Models — large, downloaded by scripts/fetch-models.sh
HikeCompanion/Resources/Models/*
!HikeCompanion/Resources/Models/README.md

# NOTE: Gemma model variants live OUTSIDE this repo at ../gemma-variants/
# (see scripts/switch-gemma.sh). They're not under this .gitignore's
# scope — kept sibling-of-repo to stay out of git AND out of the .app
# bundle (which would otherwise pull them in via the Resources/Models
# blue-folder reference).

# Strip-script backups — kept locally as a safety net, never committed
scripts/backups/

# Per-developer xcodegen overrides (signing team, bundle ID, etc.).
# When this file exists, scripts/generate-project.sh merges it on top of
# project.yml so each developer can pin their own Apple ID / Team without
# polluting the upstream spec.
project.local.yml

# Finetune results — large JSON outputs, regenerated by training runs
finetune/results/

# Finetune data — generated by prepare_plantnet*.py / prepare_na_plantae.py,
# never committed. Includes local symlinks to data hosted elsewhere on
# the dev machine. The post-restructure path is src/finetune/data/; the
# legacy top-level finetune/data/ path is kept too for older worktrees.
finetune/data/*
!finetune/data/sample
!finetune/data/sample/**
src/finetune/data/*
!src/finetune/data/sample
!src/finetune/data/sample/**

# Quantization experiment outputs — large model dirs, eval JSONs.
# Pushed to HF, not git.
quantization/results/

# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Output WAVs
*.wav

# RAG pipeline dev artifacts. The .embeddings.f16 files are
# reproducible from chunks + scripts/embed-rag-corpus.py and live
# canonically in HikeCompanion/Resources/RAG/ for the iOS bundle.
rag-poc/*.embeddings.f16

# Local Python venv for the RAG embedding pipeline. Recreate via:
#   python3 -m venv .venv-rag
#   source .venv-rag/bin/activate
#   pip install -r scripts/rag-requirements.txt
.venv-rag/

# Unsloth compiled kernel cache (generated at runtime, any path)
unsloth_compiled_cache/

# Wandb run artifacts — wandb writes to ./wandb/ by default (and to
# {output_dir}/wandb/ when WANDB_DIR is set). May contain absolute
# local paths in run metadata; never commit. Use ``wandb sync`` to
# push offline runs from a connected box if needed.
# (Per-run metrics.jsonl from JsonlMetricsCallback lives under
# {output_dir}/, which is already gitignored via finetune/.gitignore.)
wandb/
**/wandb/

# gptqmodel writes a per-run progress log at the CWD; not interesting
# to track (large, regenerated every run).
gptq_log_*.log

# Trailogy convention: all generated artefacts live OUTSIDE the repo
# (sibling-of-repo data/ dir; see src/data_mix/src/env_paths.py for
# the resolved layout). The legacy in-repo paths below are kept as
# defense-in-depth in case someone overrides defaults to write inside
# the working tree.
data_mix/_local/
src/data_mix/_local/
inaturalist_na_plantae/
inaturalist_na_plantae_prepared/
assets/run_results/

# Defensive: pre-processing JSONL snapshots tend to carry absolute
# paths from the host that built them. Keep them off git so the public
# repo never re-acquires the privacy leak we scrubbed from history.
*.jsonl.pre_*
*.jsonl.bk
*.jsonl.bak
