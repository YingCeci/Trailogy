# Xcode
*.xcodeproj/
!project.yml
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
DerivedData/
build/
*.dSYM.zip
*.dSYM

# SwiftPM (anywhere in tree, including vendored packages under external/)
.swiftpm/
**/.build/
Package.resolved
external/**/Package.resolved

# Models — large, downloaded by scripts/fetch-models.sh
HikeCompanion/Resources/Models/*
!HikeCompanion/Resources/Models/README.md

# Strip-script backups — kept locally as a safety net, never committed
scripts/backups/

# Per-developer xcodegen overrides (signing team, bundle ID, etc.).
# When this file exists, scripts/generate-project.sh merges it on top of
# project.yml so each developer can pin their own Apple ID / Team without
# polluting the upstream spec.
project.local.yml

# macOS
.DS_Store

# Output WAVs
*.wav
